# Copie para ".env" e preencha. NUNCA compartilhe o BOT_TOKEN.

# Token do bot, gerado pelo @BotFather no Telegram:
BOT_TOKEN=

# Seu ID do Telegram (e de outros admins), separados por vírgula.
# Para descobrir seu ID: fale com o bot e envie /id (depois que ele estiver no ar),
# ou use o bot @userinfobot no Telegram.
ADMIN_IDS=

# Opcionais:
CLUB_NAME=GUERRA Clube de Tiro
TZ=America/Sao_Paulo
PORT=8000
DB_PATH=/app/data/tiro_guerra.db
